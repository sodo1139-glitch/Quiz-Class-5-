@charset "utf-8";

@import url("https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&family=Cairo:wght@300;400;600;700;900&display=swap");

:root { --gold: #c9a84c; --gold-light: #f0d080; --dark: #0c0b09; --dark2: #181410; --dark3: #231c12; --red: #7a1515; --red-bright: #cc2222; --cream: #f4e8d0; --tan: #b09060; --glow: rgba(201,168,76,0.3); --green: #2d7a3a; }

* { margin: 0px; padding: 0px; box-sizing: border-box; }

body { background: var(--dark); color: var(--cream); font-family: Cairo, sans-serif; min-height: 100vh; overflow-x: hidden; }

body::before { content: ""; position: fixed; inset: 0px; pointer-events: none; z-index: 0; background: radial-gradient(70% 50% at 50% 0%, rgba(122, 21, 21, 0.2) 0%, transparent 65%), radial-gradient(50% 40% at 90% 90%, rgba(201, 168, 76, 0.1) 0%, transparent 55%), repeating-linear-gradient(0deg, transparent, transparent 80px, rgba(201, 168, 76, 0.02) 80px, rgba(201, 168, 76, 0.02) 81px), repeating-linear-gradient(90deg, transparent, transparent 80px, rgba(201, 168, 76, 0.02) 80px, rgba(201, 168, 76, 0.02) 81px); }

.screen { display: none; flex-direction: column; align-items: center; justify-content: center; min-height: 100vh; padding: 24px 16px; position: relative; z-index: 1; animation: 0.45s ease 0s 1 normal none running fadeUp; }

.screen.active { display: flex; }

@keyframes fadeUp { 
  0% { opacity: 0; transform: translateY(18px); }
  100% { opacity: 1; transform: translateY(0px); }
}

.game-title { font-family: Amiri, serif; font-size: clamp(2rem, 7vw, 4rem); font-weight: 700; background: linear-gradient(135deg, rgb(240, 208, 128), rgb(201, 168, 76), rgb(138, 96, 16)) text; -webkit-text-fill-color: transparent; text-align: center; line-height: 1.2; }

.subtitle { font-size: 0.82rem; color: var(--tan); letter-spacing: 5px; text-transform: uppercase; margin-top: 6px; text-align: center; }

.divider { width: 180px; height: 2px; background: linear-gradient(90deg,transparent,var(--gold),transparent); margin: 18px auto; }

.card { background: linear-gradient(150deg, rgba(35, 28, 18, 0.97), rgba(24, 20, 16, 0.99)); border: 1px solid rgba(201, 168, 76, 0.28); border-radius: 4px; padding: 28px 24px; width: 100%; max-width: 600px; position: relative; box-shadow: rgba(0, 0, 0, 0.7) 0px 10px 50px, rgba(201, 168, 76, 0.12) 0px 1px 0px inset; }

.card::before, .card::after { content: ""; position: absolute; width: 18px; height: 18px; border-color: var(--gold); border-style: solid; opacity: 0.5; }

.card::before { top: 7px; right: 7px; border-width: 2px 2px 0px 0px; }

.card::after { bottom: 7px; left: 7px; border-width: 0px 0px 2px 2px; }

.btn { background: linear-gradient(135deg, rgb(58, 42, 16), rgb(34, 24, 8)); border: 1px solid var(--gold); color: var(--gold-light); font-family: Cairo, sans-serif; font-size: 1rem; font-weight: 700; padding: 13px 30px; border-radius: 3px; cursor: pointer; transition: 0.22s; letter-spacing: 1px; position: relative; overflow: hidden; display: inline-block; }

.btn:hover { box-shadow: 0 0 28px var(--glow),0 4px 16px rgba(0,0,0,.4); transform: translateY(-2px); }

.btn:active { transform: translateY(0px); }

.btn:disabled { opacity: 0.4; cursor: not-allowed; transform: none; box-shadow: none; }

.btn-red { border-color: var(--red-bright); color: rgb(255, 144, 144); background: linear-gradient(135deg, rgb(42, 8, 8), rgb(24, 4, 4)); }

.btn-red:hover { box-shadow: rgba(204, 34, 34, 0.4) 0px 0px 28px; }

.btn-full { width: 100%; text-align: center; }

.inp { width: 100%; background: rgba(8, 6, 3, 0.7); border: 1px solid rgba(201, 168, 76, 0.3); border-radius: 3px; color: var(--cream); font-family: Cairo, sans-serif; font-size: 1.05rem; padding: 13px 15px; outline: none; transition: 0.2s; text-align: right; }

.inp:focus { border-color: var(--gold); box-shadow: rgba(201, 168, 76, 0.18) 0px 0px 14px; }

.inp::placeholder { color: rgba(176, 144, 96, 0.4); }

.lbl { font-size: 0.78rem; color: var(--tan); letter-spacing: 2px; text-transform: uppercase; margin-bottom: 6px; display: block; }

#qr-wrap { background: rgb(255, 255, 255); padding: 14px; border-radius: 4px; display: inline-block; border: 3px solid var(--gold); box-shadow: rgba(201, 168, 76, 0.25) 0px 0px 30px; }

.room-code { font-family: Amiri, serif; font-size: 3.2rem; color: var(--gold-light); letter-spacing: 14px; text-align: center; text-shadow: 0 0 20px var(--glow); }

.player-item { display: flex; align-items: center; gap: 10px; padding: 9px 13px; background: rgba(201, 168, 76, 0.05); border: 1px solid rgba(201, 168, 76, 0.13); border-radius: 3px; margin-bottom: 7px; animation: 0.3s ease 0s 1 normal none running slideIn; }

@keyframes slideIn { 
  0% { opacity: 0; transform: translateX(16px); }
  100% { opacity: 1; transform: translateX(0px); }
}

.avatar { width: 34px; height: 34px; border-radius: 50%; background: linear-gradient(135deg,var(--red),var(--dark3)); border: 2px solid var(--gold); display: flex; align-items: center; justify-content: center; font-size: 0.95rem; font-weight: 700; color: var(--gold-light); flex-shrink: 0; }

.prog-bar { width: 100%; height: 5px; background: rgba(201, 168, 76, 0.12); border-radius: 3px; overflow: hidden; margin-bottom: 18px; }

.prog-fill { height: 100%; background: linear-gradient(90deg,var(--gold),var(--gold-light)); transition: width 0.4s; border-radius: 3px; }

.timer-wrap { position: relative; width: 76px; height: 76px; margin: 0px auto 14px; }

.timer-wrap svg { transform: rotate(-90deg); }

circle { fill: none; stroke-width: 6; }

.tc-bg { stroke: rgba(201, 168, 76, 0.13); }

.tc-fill { stroke: var(--gold); stroke-dasharray: 214; stroke-dashoffset: 0; transition: stroke-dashoffset 1s linear, stroke 0.5s; stroke-linecap: round; }

.timer-num { position: absolute; inset: 0px; display: flex; align-items: center; justify-content: center; font-family: Amiri, serif; font-size: 1.55rem; font-weight: 700; color: var(--gold-light); }

.opts { display: grid; grid-template-columns: 1fr 1fr; gap: 11px; }

.opt { background: rgba(18, 14, 8, 0.8); border: 1px solid rgba(201, 168, 76, 0.22); color: var(--cream); font-family: Cairo, sans-serif; font-size: 0.9rem; font-weight: 600; padding: 15px 12px; border-radius: 3px; cursor: pointer; transition: 0.2s; text-align: center; line-height: 1.4; }

.opt:hover:not(:disabled) { border-color: var(--gold); background: rgba(201, 168, 76, 0.09); box-shadow: rgba(201, 168, 76, 0.18) 0px 0px 14px; transform: translateY(-2px); }

.opt:disabled { cursor: default; }

.opt.correct { background: rgba(18, 70, 26, 0.85) !important; border-color: rgb(76, 175, 80) !important; color: rgb(128, 255, 128) !important; box-shadow: rgba(76, 175, 80, 0.3) 0px 0px 18px !important; }

.opt.wrong { background: rgba(90, 10, 10, 0.85) !important; border-color: var(--red-bright) !important; color: rgb(255, 128, 128) !important; opacity: 0.85 !important; }

.sc-row { display: flex; align-items: center; gap: 12px; padding: 12px 16px; background: rgba(201, 168, 76, 0.04); border: 1px solid rgba(201, 168, 76, 0.13); border-radius: 3px; margin-bottom: 8px; transition: 0.35s; }

.sc-row:nth-child(1) { border-color: rgba(255, 215, 0, 0.45); background: rgba(255, 215, 0, 0.06); }

.sc-row:nth-child(2) { border-color: rgba(192, 192, 192, 0.35); }

.sc-row:nth-child(3) { border-color: rgba(205, 127, 50, 0.35); }

.sc-medal { font-size: 1.2rem; width: 32px; text-align: center; flex-shrink: 0; }

.sc-name { flex: 1 1 0%; font-weight: 600; }

.sc-delta { font-size: 0.78rem; color: rgb(93, 186, 106); font-weight: 700; }

.sc-pts { font-family: Amiri, serif; font-size: 1.35rem; color: var(--gold-light); font-weight: 700; }

.rev-box { text-align: center; padding: 18px; border-radius: 3px; margin-bottom: 16px; }

.rev-box.ok { background: rgba(18, 70, 26, 0.4); border: 1px solid rgb(76, 175, 80); }

.rev-box.bad { background: rgba(90, 10, 10, 0.4); border: 1px solid var(--red-bright); }

.rev-icon { font-size: 2.4rem; }

.rev-text { font-size: 1.05rem; margin-top: 7px; }

.fact { background: rgba(201, 168, 76, 0.05); border: 1px solid rgba(201, 168, 76, 0.22); border-radius: 3px; padding: 13px 16px; font-size: 0.86rem; color: var(--tan); line-height: 1.75; }

.fact strong { color: var(--gold-light); }

.dot { display: inline-block; width: 9px; height: 9px; background: var(--gold); border-radius: 50%; animation: 1.3s ease 0s infinite normal none running pls; margin: 0px 3px; }

.dot:nth-child(2) { animation-delay: 0.2s; }

.dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes pls { 
  0%, 100% { opacity: 0.2; transform: scale(0.8); }
  50% { opacity: 1; transform: scale(1.2); }
}

.trophy { font-size: 5rem; text-align: center; animation: 1s ease-in-out 0s infinite alternate none running bob; }

@keyframes bob { 
  100% { transform: translateY(-10px) scale(1.04); }
}

.status-msg { text-align: center; font-size: 0.88rem; color: var(--tan); margin-top: 8px; min-height: 20px; }

.err-msg { color: rgb(255, 112, 112); text-align: center; font-size: 0.85rem; margin-top: 8px; }

.tc { text-align: center; }

.mt8 { margin-top: 8px; }

.mt12 { margin-top: 12px; }

.mt16 { margin-top: 16px; }

.mt20 { margin-top: 20px; }

.mt24 { margin-top: 24px; }

.mb8 { margin-bottom: 8px; }

.mb12 { margin-bottom: 12px; }

.mb16 { margin-bottom: 16px; }

.flex { display: flex; }

.gap12 { gap: 12px; }

.jc { justify-content: center; }

.q-num { font-size: 0.76rem; color: var(--tan); letter-spacing: 3px; text-transform: uppercase; }

.q-text { font-family: Amiri, serif; font-size: clamp(1.1rem, 3vw, 1.45rem); color: var(--cream); line-height: 1.75; text-align: center; margin-bottom: 22px; }

.pts-badge { font-family: Amiri, serif; font-size: 1.05rem; color: var(--gold); font-weight: 700; }

.conn-indicator { display: inline-flex; align-items: center; gap: 7px; font-size: 0.78rem; color: var(--tan); }

.conn-dot { width: 8px; height: 8px; border-radius: 50%; background: rgb(76, 175, 80); animation: 2s ease 0s infinite normal none running pulse-g; }

@keyframes pulse-g { 
  0%, 100% { box-shadow: rgba(76, 175, 80, 0.5) 0px 0px 0px 0px; }
  50% { box-shadow: rgba(76, 175, 80, 0) 0px 0px 0px 6px; }
}

@media (max-width: 480px) {
  .opts { grid-template-columns: 1fr; }
  .card { padding: 18px 14px; }
}
